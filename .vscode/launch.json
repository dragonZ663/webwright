{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: webwright main",
            "type": "debugpy",
            "request": "launch",
            "module": "webwright.run.cli",
            "args": [
                "main",
                "--task", "找到bilibili播放量最高的langchain教程",
                "--task-id", "langchain_Bilibili",
                "--start-url", "https://www.bilibili.com/",
                "--config", "base.yaml",
                "--config", "custom_openrouter.yaml",
                "--output-dir", "outputs/default",
            ],
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src",
            },
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Python: webwright main (自定义任务)",
            "type": "debugpy",
            "request": "launch",
            "module": "webwright.run.cli",
            "args": [
                "main",
                "--task", "",
                "--start-url", "https://www.example.com/",
                "--config", "base.yaml",
                "--config", "custom_openrouter.yaml",
                "--output-dir", "outputs/default",
                "--debug"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Python: webwright doctor",
            "type": "debugpy",
            "request": "launch",
            "module": "webwright.run.cli",
            "args": ["doctor"],
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Python: Attach (远程调试)",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5678
            },
            "justMyCode": true
        }
    ]
}
